# SmartPOS AI Community Edition - Backend Local Environment
# Copy to backend/.env for local development. Values are demo-safe placeholders.

APP_ENV=development
DEBUG=true
SECRET_KEY=community-demo-secret-change-locally

DATABASE_URL=postgresql+asyncpg://smartpos:smartpos_demo_password@localhost:5432/smartpos
DATABASE_SYNC_URL=postgresql+psycopg2://smartpos:smartpos_demo_password@localhost:5432/smartpos
SQLITE_URL=sqlite+aiosqlite:///./smartpos_local.db

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
AES_ENCRYPTION_KEY=community-demo-aes-key-32-bytes!!

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_URL=redis://localhost:6379/2

ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
ALLOWED_HOSTS=["*"]

ENABLE_DEMO_AUTH=true
DEMO_USER_EMAIL=demo@smartpos.community
ENABLE_ADVANCED_ANALYTICS=false
ENABLE_VOICE=true
